        label.set_text(ll_lbl_u, sl_lbl_txt("Lunch Low", l_prc_u))
        label.set_size(ll_lbl_u, lbl_sz(sl_lbl_sz))
        label.set_textcolor(ll_lbl_u, l_vis_u ? color.new(lunch_col, 0) : na)

