            array.set(nypm_ll_t, i, nypm_lo_t)
        box.set_top(b,           array.get(nypm_his, i))
        box.set_bottom(b,        array.get(nypm_los, i))
        box.set_left(b,          array.get(nypm_lt,  i))
        box.set_right(b,         array.get(nypm_rt,  i))
        box.set_bgcolor(b,       show_nypm and tf_ok ? nypm_col : na)
        box.set_border_color(b,  show_nypm and tf_ok ? color.new(nypm_col, 0) : na)
        box.set_border_width(b,  show_nypm and tf_ok ? bw_in : 0)
        box.set_border_style(b,  ls(bsty_in))
        box.set_text(b,          show_nypm and show_box_lbl ? "NY PM" : "")
        box.set_text_color(b,    box_lbl_col)
        box.set_text_size(b,     lbl_sz(box_lbl_size))
        box.set_text_halign(b,   bx_halign(box_lbl_pos))
        box.set_text_valign(b,   bx_valign(box_lbl_pos))
        float h_prc_p = array.get(nypm_his,  i)
        float l_prc_p = array.get(nypm_los,  i)
        int   h_t1_p  = array.get(nypm_hl_t, i)
        int   l_t1_p  = array.get(nypm_ll_t, i)
        line  h_ln_p  = array.get(nypm_hl_lns, i)
        line  l_ln_p  = array.get(nypm_ll_lns, i)
        int   h_tkn_p = array.get(nypm_hl_tkn, i)
        int   l_tkn_p = array.get(nypm_ll_tkn, i)
        if not live
            if na(h_tkn_p) and high >= h_prc_p
                h_tkn_p := bar_index
                array.set(nypm_hl_tkn, i, bar_index)
            if na(l_tkn_p) and low <= l_prc_p
                l_tkn_p := bar_index
                array.set(nypm_ll_tkn, i, bar_index)
        bool h_tk_p = not na(h_tkn_p)
        bool l_tk_p = not na(l_tkn_p)
        int  h_x2_p = h_tk_p ? time + (h_tkn_p - bar_index + sl_grace) * bar_ms : time + extend_ms
        int  l_x2_p = l_tk_p ? time + (l_tkn_p - bar_index + sl_grace) * bar_ms : time + extend_ms
        bool h_vis_p = show_sl_lines and sl_show_nypm and tf_ok and not live
        bool l_vis_p = show_sl_lines and sl_show_nypm and tf_ok and not live
        line.set_x1(h_ln_p, h_t1_p)
        line.set_x2(h_ln_p, h_x2_p)
        line.set_y1(h_ln_p, h_prc_p)
        line.set_y2(h_ln_p, h_prc_p)
        line.set_color(h_ln_p, h_vis_p ? color.new(nypm_col, 0) : na)
        line.set_width(h_ln_p, h_vis_p ? sl_w : 0)
        line.set_style(h_ln_p, ls(sl_sty_in))
        line.set_x1(l_ln_p, l_t1_p)
        line.set_x2(l_ln_p, l_x2_p)
        line.set_y1(l_ln_p, l_prc_p)
        line.set_y2(l_ln_p, l_prc_p)
        line.set_color(l_ln_p, l_vis_p ? color.new(nypm_col, 0) : na)
        line.set_width(l_ln_p, l_vis_p ? sl_w : 0)
        line.set_style(l_ln_p, ls(sl_sty_in))
        label hl_lbl_p = array.get(nypm_hl_lbls, i)
        label ll_lbl_p = array.get(nypm_ll_lbls, i)
        label.set_x(hl_lbl_p, sl_lbl_x(sl_lbl_pos, h_t1_p, h_x2_p))
        label.set_y(hl_lbl_p, h_prc_p)
        label.set_style(hl_lbl_p, sl_lbl_sty_hi(sl_lbl_pos))
        label.set_text(hl_lbl_p, sl_lbl_txt("PM High", h_prc_p))
        label.set_size(hl_lbl_p, lbl_sz(sl_lbl_sz))
        label.set_textcolor(hl_lbl_p, h_vis_p ? color.new(nypm_col, 0) : na)
        label.set_x(ll_lbl_p, sl_lbl_x(sl_lbl_pos, l_t1_p, l_x2_p))
        label.set_y(ll_lbl_p, l_prc_p)
        label.set_style(ll_lbl_p, sl_lbl_sty_lo(sl_lbl_pos))
        label.set_text(ll_lbl_p, sl_lbl_txt("PM Low", l_prc_p))
        label.set_size(ll_lbl_p, lbl_sz(sl_lbl_sz))
        label.set_textcolor(ll_lbl_p, l_vis_p ? color.new(nypm_col, 0) : na)

// ════════════════════════════════════════════════════════════════════════════
// DAILY & WEEKLY LEVELS
// ════════════════════════════════════════════════════════════════════════════

// Previous day & week H/L via higher-timeframe security
float pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
float pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
float pwh = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_on)
float pwl = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_on)

bool new_day_d  = ta.change(time("D")) != 0
bool new_week_w = ta.change(time("W")) != 0

var line  pdh_ln  = na
var line  pdl_ln  = na
var line  pwh_ln  = na
var line  pwl_ln  = na
var label pdh_lbl_obj = na
var label pdl_lbl_obj = na
var label pwh_lbl_obj = na
var label pwl_lbl_obj = na
var int   pdh_tkn = na
var int   pdl_tkn = na
var int   pwh_tkn = na
var int   pwl_tkn = na

// Recreate daily lines at the start of each new day
if (new_day_d or na(pdh_ln)) and not na(pdh)
    line.delete(pdh_ln)
    line.delete(pdl_ln)
    label.delete(pdh_lbl_obj)
    label.delete(pdl_lbl_obj)
    pdh_tkn := na
    pdl_tkn := na
    pdh_ln      := line.new(time, pdh, time + extend_ms, pdh, xloc=xloc.bar_time, color=na, width=1)
    pdl_ln      := line.new(time, pdl, time + extend_ms, pdl, xloc=xloc.bar_time, color=na, width=1)
    pdh_lbl_obj := label.new(time + extend_ms, pdh, pdh_lbl, xloc=xloc.bar_time,
                              style=label.style_label_up, color=na, textcolor=na, size=size.small)
    pdl_lbl_obj := label.new(time + extend_ms, pdl, pdl_lbl, xloc=xloc.bar_time,
                              style=label.style_label_down, color=na, textcolor=na, size=size.small)

// Recreate weekly lines at the start of each new week
if (new_week_w or na(pwh_ln)) and not na(pwh)
    line.delete(pwh_ln)
    line.delete(pwl_ln)
    label.delete(pwh_lbl_obj)
    label.delete(pwl_lbl_obj)
    pwh_tkn := na
    pwl_tkn := na
    pwh_ln      := line.new(time, pwh, time + extend_ms, pwh, xloc=xloc.bar_time, color=na, width=1)
    pwl_ln      := line.new(time, pwl, time + extend_ms, pwl, xloc=xloc.bar_time, color=na, width=1)
    pwh_lbl_obj := label.new(time + extend_ms, pwh, pwh_lbl, xloc=xloc.bar_time,
                              style=label.style_label_down, color=na, textcolor=na, size=size.small)
    pwl_lbl_obj := label.new(time + extend_ms, pwl, pwl_lbl, xloc=xloc.bar_time,
                              style=label.style_label_up, color=na, textcolor=na, size=size.small)

// Update all properties every bar for toggle/color/style/extension responsiveness
int lbl_x = time + extend_ms

if not na(pdh_ln)
    if na(pdh_tkn) and high >= pdh
        pdh_tkn := bar_index
    bool pdh_taken = not na(pdh_tkn)
    bool pdh_vis   = show_pdh and (not dw_hide_taken or not pdh_taken or (bar_index - pdh_tkn) <= dw_grace)
    line.set_y1(pdh_ln, pdh)
    line.set_y2(pdh_ln, pdh)
    line.set_x2(pdh_ln, lbl_x)
    line.set_color(pdh_ln, pdh_vis ? pdh_col : na)
    line.set_style(pdh_ln, ls(pdh_sty_in))
    line.set_width(pdh_ln, pdh_vis ? pdh_w : 0)
    label.set_x(pdh_lbl_obj, lbl_x)
    label.set_y(pdh_lbl_obj, pdh)
    label.set_text(pdh_lbl_obj, pdh_lbl)
    label.set_textcolor(pdh_lbl_obj, pdh_vis and show_dw_labels ? pdh_col : na)

if not na(pdl_ln)
    if na(pdl_tkn) and low <= pdl
        pdl_tkn := bar_index
    bool pdl_taken = not na(pdl_tkn)
    bool pdl_vis   = show_pdl and (not dw_hide_taken or not pdl_taken or (bar_index - pdl_tkn) <= dw_grace)
    line.set_y1(pdl_ln, pdl)
    line.set_y2(pdl_ln, pdl)
    line.set_x2(pdl_ln, lbl_x)
    line.set_color(pdl_ln, pdl_vis ? pdl_col : na)
    line.set_style(pdl_ln, ls(pdl_sty_in))
    line.set_width(pdl_ln, pdl_vis ? pdl_w : 0)
    label.set_x(pdl_lbl_obj, lbl_x)
    label.set_y(pdl_lbl_obj, pdl)
    label.set_text(pdl_lbl_obj, pdl_lbl)
    label.set_textcolor(pdl_lbl_obj, pdl_vis and show_dw_labels ? pdl_col : na)

if not na(pwh_ln)
    if na(pwh_tkn) and high >= pwh
        pwh_tkn := bar_index
    bool pwh_taken = not na(pwh_tkn)
    bool pwh_vis   = show_pwh and (not dw_hide_taken or not pwh_taken or (bar_index - pwh_tkn) <= dw_grace)
    line.set_y1(pwh_ln, pwh)
    line.set_y2(pwh_ln, pwh)
    line.set_x2(pwh_ln, lbl_x)
    line.set_color(pwh_ln, pwh_vis ? pwh_col : na)
    line.set_style(pwh_ln, ls(pwh_sty_in))
    line.set_width(pwh_ln, pwh_vis ? pwh_w : 0)
    label.set_x(pwh_lbl_obj, lbl_x)
    label.set_y(pwh_lbl_obj, pwh)
    label.set_text(pwh_lbl_obj, pwh_lbl)
    label.set_textcolor(pwh_lbl_obj, pwh_vis and show_dw_labels ? pwh_col : na)

if not na(pwl_ln)
    if na(pwl_tkn) and low <= pwl
        pwl_tkn := bar_index
    bool pwl_taken = not na(pwl_tkn)
    bool pwl_vis   = show_pwl and (not dw_hide_taken or not pwl_taken or (bar_index - pwl_tkn) <= dw_grace)
    line.set_y1(pwl_ln, pwl)
    line.set_y2(pwl_ln, pwl)
    line.set_x2(pwl_ln, lbl_x)
    line.set_color(pwl_ln, pwl_vis ? pwl_col : na)
    line.set_style(pwl_ln, ls(pwl_sty_in))
    line.set_width(pwl_ln, pwl_vis ? pwl_w : 0)
    label.set_x(pwl_lbl_obj, lbl_x)
    label.set_y(pwl_lbl_obj, pwl)
    label.set_text(pwl_lbl_obj, pwl_lbl)
    label.set_textcolor(pwl_lbl_obj, pwl_vis and show_dw_labels ? pwl_col : na)
